# Alpha Vantage API Configuration
# Get your free API key at: https://www.alphavantage.co/support/#api-key
# Free tier includes 25 requests per day (enough for ~6 ticker lookups)
# Premium plans available for higher limits

ALPHA_VANTAGE_API_KEY=your_api_key_here

# Anthropic API Configuration
# Get your key at: https://console.anthropic.com/
# Used by Phases 17-20 (thesis, decay-watcher, news interpreter, daily ranker).

ANTHROPIC_API_KEY=your_anthropic_key_here

# Reddit OAuth (Phase 3 social-sentiment)
# Optional in v1 — Reddit ingestion uses the public JSON endpoints,
# which require no key. Set these only when wiring the future
# `roux` / PRAW OAuth backend.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
