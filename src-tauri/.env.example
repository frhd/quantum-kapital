# Alpha Vantage API Configuration
# Get your free API key at: https://www.alphavantage.co/support/#api-key
# Free tier includes 25 requests per day (enough for ~6 ticker lookups).
#
# After Phase 8, AV is consulted only by the fundamentals fallback path
# (CompositeFundamentalsProvider → AlphaVantageFundamentalsProvider) when
# a symbol is not in the manual MCP store. The news pipeline is fully
# on IBKR; this key has no effect on news. Leave unset to operate
# manual-store-only.

ALPHA_VANTAGE_API_KEY=your_api_key_here

# Anthropic API Configuration
# Get your key at: https://console.anthropic.com/
# Used by Phases 17-20 (thesis, decay-watcher, news interpreter, daily ranker).

ANTHROPIC_API_KEY=your_anthropic_key_here

# LLM transport selection.
#   anthropic   (default) — POST api.anthropic.com using ANTHROPIC_API_KEY.
#   claude_cli              — spawn `claude -p` and run inference under
#                             your Claude Code subscription (no API key
#                             required). Requires `claude` v2.1+ on PATH;
#                             override the binary path with QK_CLAUDE_BINARY.
# Read by both the Tauri backend and the Python `agent/` loops so the
# whole stack flips with one var.
QK_LLM_BACKEND=anthropic

# Reddit OAuth (Phase 3 social-sentiment)
# Optional in v1 — Reddit ingestion uses the public JSON endpoints,
# which require no key. Set these only when wiring the future
# `roux` / PRAW OAuth backend.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
